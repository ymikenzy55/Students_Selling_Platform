// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String?
  role            String    @default("BUYER")
  ghanaCardNumber String?   @unique
  ghanaCardImageUrl String?
  isVerified      Boolean   @default(false)
  
  // Relations
  listings        Listing[]
  bidsPlaced      Bid[]
  messagesSent    Message[] @relation("Sender")
  messagesReceived Message[] @relation("Receiver")
  transactions    Transaction[]
  reports         Report[]  @relation("UserReports")
  reviews         Review[]  @relation("UserReviews")
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}


model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  condition   String
  category    String
  campus      String
  imageUrl    String?
  isSoldOut   Boolean  @default(false)
  
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  
  bids        Bid[]
  transactions Transaction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Bid {
  id          String   @id @default(uuid())
  amount      Float
  status      String    @default("PENDING")
  
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id])
  
  buyerId     String
  buyer       User     @relation(fields: [buyerId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model Message {
  id          String   @id @default(uuid())
  content     String
  
  senderId    String
  sender      User     @relation("Sender", fields: [senderId], references: [id])
  
  receiverId  String
  receiver    User     @relation("Receiver", fields: [receiverId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  status      String    @default("HELD_IN_ESCROW")
  
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id])
  
  buyerId     String
  buyer       User     @relation(fields: [buyerId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Report {
  id          String   @id @default(uuid())
  subject     String
  description String
  category    String   @default("GENERAL") // GENERAL, LISTING, USER, TRANSACTION
  status      String   @default("OPEN")    // OPEN, IN_REVIEW, RESOLVED
  
  reporterId  String
  reporter    User     @relation("UserReports", fields: [reporterId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id          String   @id @default(uuid())
  rating      Int      @default(5) // 1-5 stars
  title       String
  body        String
  type        String   @default("PLATFORM") // PLATFORM, SELLER, LISTING
  status      String   @default("PENDING")  // PENDING, PUBLISHED, HIDDEN
  
  authorId    String
  author      User     @relation("UserReviews", fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

